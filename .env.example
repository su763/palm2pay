# Database
DATABASE_URL=postgresql://palm2pay:palm2pay@localhost:5432/palm2pay
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-this

# AWS/S3 (for palm image storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=palm2pay-biometric-data

# Stripe (payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@palm2pay.com

# Biometric Service
BIOMETRIC_SERVICE_URL=http://localhost:8000
BIOMETRIC_API_KEY=your-biometric-api-key

# App URLs
WEB_APP_URL=http://localhost:3000
MOBILE_APP_URL=http://localhost:3001
MERCHANT_URL=http://localhost:3002
API_URL=http://localhost:4000

# Environment
NODE_ENV=development
LOG_LEVEL=debug
