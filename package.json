{
  "name": "palm2pay",
  "version": "1.0.0",
  "description": "Biometric payment ecosystem using palm recognition",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:biometric\" \"npm run dev:mobile\" \"npm run dev:web\" \"npm run dev:merchant\"",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:biometric": "npm run dev --workspace=packages/biometric",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:merchant": "npm run dev --workspace=apps/merchant",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
